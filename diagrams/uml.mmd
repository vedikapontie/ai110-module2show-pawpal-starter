classDiagram
    class Owner {
        +owner_id: str
        +name: str
        +email: str
        +preferences: list
        +created_at: datetime
        +add_pet(pet: Pet) void
        +remove_pet(pet_id: str) void
    }

    class Pet {
        +pet_id: str
        +name: str
        +species: str
        +age: int
        +notes: str
        +created_at: datetime
        +add_task(task: Task) void
        +remove_task(task_id: str) void
    }

    class Task {
        +task_id: str
        +title: str
        +description: str
        +duration_minutes: int
        +priority: str
        +scheduled_time: datetime
        +is_completed: bool
        +created_at: datetime
        +mark_complete() void
        +update_schedule(time: datetime) void
    }

    class Scheduler {
        +scheduler_id: str
        +generated_at: datetime
        +plan: list[Task]
        +schedule_tasks(tasks: list[Task], pets: list[Pet], owner: Owner) list[Task]
        +sort_tasks(tasks: list[Task]) list[Task]
        +detect_conflicts(tasks: list[Task]) list[Task]
        +explain_plan() str
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler ..> Owner : uses
    Scheduler ..> Pet : reviews
    Scheduler ..> Task : orders
